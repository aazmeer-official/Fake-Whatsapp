<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ZERO | Secure Chat</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        body { background-color: #0f172a; }
        .glass-header {
            background: rgba(30, 41, 59, 0.7);
            backdrop-filter: blur(12px);
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        }
        .chat-container {
            background-image: radial-gradient(circle at 2px 2px, rgba(255,255,255,0.05) 1px, transparent 0);
            background-size: 24px 24px;
        }
        .message-inbound {
            background: rgba(51, 65, 85, 0.8);
            border: 1px solid rgba(255, 255, 255, 0.05);
            border-radius: 18px 18px 18px 4px;
        }
        .message-outbound {
            background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%);
            box-shadow: 0 4px 15px rgba(37, 99, 235, 0.3);
            border-radius: 18px 18px 4px 18px;
        }
        .custom-scrollbar::-webkit-scrollbar { width: 5px; }
        .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: #334155; border-radius: 10px; }
    </style>
</head>
<body class="h-screen flex flex-col font-sans text-slate-200">

    <header class="glass-header sticky top-0 z-10 p-4 flex items-center justify-between">
        <div class="flex items-center gap-4">
            <div class="relative">
                <div class="w-12 h-12 bg-gradient-to-tr from-blue-600 to-cyan-400 rounded-full flex items-center justify-center shadow-lg">
                    <i class="fa-solid fa-motorcycle text-white"></i>
                </div>
                <span class="absolute bottom-0 right-0 w-3 h-3 bg-green-500 border-2 border-slate-900 rounded-full"></span>
            </div>
            <div>
                <h2 class="text-lg font-bold tracking-tight">Aazmeer</h2>
                <p class="text-xs text-blue-400 font-medium tracking-widest uppercase">CD 100 System Active</p>
            </div>
        </div>
        <div class="flex gap-4 text-slate-400">
            <button class="hover:text-white transition"><i class="fa-solid fa-magnifying-glass"></i></button>
            <button class="hover:text-white transition"><i class="fa-solid fa-ellipsis-vertical"></i></button>
        </div>
    </header>

    <main class="flex-1 overflow-y-auto p-6 space-y-6 chat-container custom-scrollbar">
        

            <% for(chat of allChats){
                if(chat.from!= "Aazmeer"){
                %>
        <a href="/chats/<%= chat._id %>"><div class="flex justify-start items-end gap-2">
                <div class="w-8 h-8 rounded-full bg-slate-700 flex items-center justify-center text-[10px] font-bold border border-slate-600">
                    <%= chat.from.toUpperCase().slice(0,2) %>
                </div>
                <div class="message-inbound max-w-[80%] p-3 shadow-xl">
                    <p class="text-xs font-bold text-blue-400 mb-1 uppercase tracking-tighter"><%= chat.from %></p>
                    <p class="text-sm"><%= chat.msg %></p>
                    <div class="text-[9px] text-slate-400 mt-2 text-right"><%= chat.created_at.toString().split(" ")[4]%></div>
                </div>
            </div></a>
        <% }else{ %>
                    <a href="/chats/<%= chat._id %>"><div class="flex justify-end items-end gap-2">
            <div class="message-outbound max-w-[80%] p-3">
                <p class="text-sm text-white"><%= chat.msg %></p>
                <div class="flex justify-end items-center gap-1 mt-2">
                    <span class="text-[9px] text-blue-100 opacity-70"><%= chat.created_at.toString().split(" ")[4] %></span>
                    <i class="fa-solid fa-check-double text-[9px] text-cyan-300"></i>
                </div>
            </div>
        </div></a>
      <%  }} %>




    </main>
    <form action="/chats" method="post">
    <footer class="p-4 bg-slate-900/50 backdrop-blur-md">
        <div class="flex items-center gap-3 max-w-4xl mx-auto bg-slate-800 rounded-2xl p-2 border border-slate-700 focus-within:border-blue-500 transition shadow-2xl">
            <button class="w-10 h-10 text-slate-400 hover:text-white transition">
                <i class="fa-solid fa-paperclip"></i>
            </button>
            <input type="text" 
                   placeholder="Type a message..." 
                   maxlength="50"
                   name="msg"
                   id="msg"
                   class="flex-1 bg-transparent border-none outline-none text-sm text-slate-200 placeholder-slate-500">
            <button class="w-10 h-10 bg-blue-600 hover:bg-blue-500 text-white rounded-xl transition flex items-center justify-center shadow-lg" type="submit">
                <i class="fa-solid fa-paper-plane text-xs"></i>
            </button>
        </div>
    </footer>
    </form>
</body>
</html>